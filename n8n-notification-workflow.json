      "parameters": {
        "fromEmail": "Dream PFE <notifications@example.com>",
        "toEmail": "={{ $json.to }}",
        "subject": "={{ $json.subject }}",
        "html": "=<div style=\"font-family: Arial, sans-serif; max-width: 620px; margin: 0 auto; color: #24114f; line-height: 1.6;\">\n  <div style=\"padding: 24px; border: 1px solid #eee7ff; border-radius: 16px; background: #fbf8ff;\">\n    <p style=\"font-size: 12px; margin: 0 0 10px; color: #7b6b9a; text-transform: uppercase; letter-spacing: .08em;\">Dream PFE</p>\n    <h2 style=\"margin: 0 0 12px; color: #2d1068; font-size: 22px;\">{{ $json.title }}</h2>\n    <p style=\"font-size: 15px; margin: 0 0 20px;\">{{ $json.message }}</p>\n    {{ $json.link ? '<a href=\"' + $json.link + '\" style=\"display: inline-block; background: #6d28d9; color: #ffffff; text-decoration: none; padding: 12px 18px; border-radius: 999px; font-weight: 700;\">Ouvrir la plateforme</a>' : '' }}\n  </div>\n  <p style=\"font-size: 12px; color: #7b6b9a; margin-top: 16px;\">Cet email a ete envoye automatiquement par Dream PFE.</p>\n</div>",
        "options": {
          "allowUnauthorizedCerts": false
        }
      },
