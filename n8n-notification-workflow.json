    {
      "parameters": {
        "jsCode": "const body = $json.body || {};\nconst required = ['to', 'subject', 'title', 'message'];\nconst missing = required.filter((key) => typeof body[key] !== 'string' || body[key].trim() === '');\n\nif (missing.length > 0) {\n  return [{ json: { valid: false, error: `Missing required fields: ${missing.join(', ')}` } }];\n}\n\nreturn [{\n  json: {\n    valid: true,\n    event: body.event || 'notification_created',\n    link: body.link || '',\n    message: body.message.trim(),\n    notificationId: body.notificationId,\n    subject: body.subject.trim(),\n    title: body.title.trim(),\n    to: body.to.trim(),\n  },\n}];"
      },
      "id": "b392fe8e-9ad6-4102-922f-a5a6f20569e0",
